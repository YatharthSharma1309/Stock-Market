# StockSim Pro environment variables
# Copy this file to .env and fill in real values before starting the stack.
# Never commit .env to version control.
#
# Generate a strong SECRET_KEY with:
#   openssl rand -hex 32

# Auth
SECRET_KEY=replace-me-with-openssl-rand-hex-32

# Database
POSTGRES_USER=stocksim
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=stocksim_db

# Redis
# Used in production only; dev docker-compose.yml has no password.
REDIS_PASSWORD=change-me-redis-password

# AI
# Get your key at https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-...

# URLs
# Set to your public domain in production, for example:
#   https://stocksim.yourdomain.com
FRONTEND_URL=http://localhost:3000

# Public domain name used in production HTTPS setup.
# Example: stocksim.yourdomain.com
DOMAIN=stocksim.example.com

# Backend tuning
# Number of gunicorn workers in production.
WEB_CONCURRENCY=4

# Observability
# Optional Sentry project DSN.
SENTRY_DSN=

# Backups
# Production database backup retention window in days.
BACKUP_RETAIN_DAYS=7
