# ── StockSim Pro — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in real values before starting the stack.
# NEVER commit .env to version control.
#
# Generate a strong SECRET_KEY with:
#   openssl rand -hex 32

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=replace-me-with-openssl-rand-hex-32

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=stocksim
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=stocksim_db

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used in production only; dev docker-compose.yml has no password
REDIS_PASSWORD=change-me-redis-password

# ── AI (Anthropic Claude) ─────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-...

# ── URLs ──────────────────────────────────────────────────────────────────────
# Set to your public domain in production (e.g. https://stocksim.yourdomain.com)
FRONTEND_URL=http://localhost:3000

# ── Backend tuning (optional) ─────────────────────────────────────────────────
# Number of gunicorn workers in production (default 4)
WEB_CONCURRENCY=4
